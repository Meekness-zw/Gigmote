    font-family: "Font Awesome 5 Pro";
    font-weight: 300;
    content: "\f178";
    margin-left: 10px;
    font-size: 20px;
    line-height: 100%;
  }
  
	/*Apply "..." after 2 lines of text */
.truncate-2-lines {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
}

