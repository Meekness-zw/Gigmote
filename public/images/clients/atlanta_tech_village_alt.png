  }
  .w-slider-dot {
  	margin-bottom: 0px;
  }

/* Utility Class Code */
  .truncate {
  	text-overflow: ellipsis !important;
  }
  .cta::after {
    display: inline-block;
    font-style: normal;
    font-variant: normal;
    text-rendering: auto;
